def print_numbers(A, B):
    """Выводит числа от A до B, состоящие только из цифр 1,3,4,8,9."""
    
    # Если A больше B - меняем их местами
    if A > B:
        A, B = B, A  # Теперь A всегда меньше или равно B
    
    # Разрешённые цифры
    allowed = {'1', '3', '4', '8', '9'}
    
    # Перебираем все числа от A до B включительно
    for num in range(A, B + 1):
        # Проверяем, все ли цифры числа входят в разрешённые
        if all(digit in allowed for digit in str(num)):
            print(num, end=" ")  # Выводим число через пробел


# Запускаем функцию с примером
print_numbers(19, 50)
