def discounted_price(price, card, data):
    """Рассчитывает цену товара со скидкой."""
    
    discount = 0  # Начальная скидка
    
    # Скидка от суммы покупки
    if price > 29999:
        discount = 10
    elif price > 19999:
        discount = 7
    elif price > 14999:
        discount = 5
    elif price > 4999:
        discount = 3
    
    # Дополнительная скидка за наличие карты
    if card == "да" or card == "Да":
        discount += 5
    
    # Дополнительная скидка в праздничную дату
    if data == "28.03.2026":
        discount += 3
        print("Поздравляю! Сегодня день уважения кошек!")
    
    # Ограничиваем максимальную скидку 15%
    if discount > 15:
        discount = 15
    
    # Вычисляем итоговую цену
    result = (price / 100) * (100 - discount)
    return round(result, 2)  # Округляем до двух знаков


# Запрашиваем данные у пользователя
price = int(input("Введите стоимость товара: "))
card = input("Являетесь ли вы обладателем карты? ")
data = input("Введите сегодняшнюю дату (28.03.2026): ")

# Выводим результат
print(f"Цена со скидкой: {discounted_price(price, card, data)}")
