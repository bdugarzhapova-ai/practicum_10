def is_prime(n):
    """Проверяет, является ли число простым."""
    
    # Простые числа начинаются с 2 (0 и 1 - не простые)
    if n < 2:
        return False
    
    # Проверяем делители от 2 до n-1
    for i in range(2, n):
        if n % i == 0:  # Если делится без остатка
            return False  # Значит, не простое
    
    return True  # Если делителей не нашли - число простое


# Запрашиваем число у пользователя
N = int(input("Введите число N: "))

# Выводим все простые числа от 1 до N
print(f"Простые числа от 1 до {N}:")
for i in range(1, N + 1):
    if is_prime(i):  # Если число простое
        print(i, end=" ")  # Выводим его через пробел
