def make_payment(P):
    """Проверяет и обрабатывает платёж по кредитной карте."""
    
    credit_limit = 1000  # Кредитный лимит
    min_payment = 20     # Минимальный платёж
    
    # Проверяем, что сумма платежа в допустимых пределах
    if int(P) >= min_payment and int(P) <= credit_limit:
        print("Успех")           # Платёж прошёл
    else:
        print("Повторить попытку")  # Сумма не подходит
    
    return f"Оплата: {P}"  # Возвращаем строку с суммой


# Запрашиваем сумму платежа у пользователя
P = input("Введите сумму оплаты: ")
make_payment(P)  # Вызываем функцию
