def get_card_value():
    """Рассчитывает итоговую стоимость подарочной карты с бонусом."""
    
    # Запрашиваем номинал карты у пользователя
    price = int(input("Введите стоимость карты (5, 10, 25, 50, 100): "))
    
    # Начисляем бонус в зависимости от номинала
    if price == 5 or price == 10:
        bonus = 0      # Бонуса нет
    elif price == 25:
        bonus = 3      # Бонус 3$
    elif price == 50:
        bonus = 8      # Бонус 8$
    elif price == 100:
        bonus = 20     # Бонус 20$
    else:
        # Если номинал не из списка - выводим ошибку
        print("Ошибка, допустимые значения: 5, 10, 25, 50, 100")
        return None    # Выходим из функции
    
    # Считаем итоговую сумму (карта + бонус)
    total = price + bonus
    
    # Выводим результат
    print(f"Стоимость карты: ${price}")
    print(f"Бонус: ${bonus}")
    print(f"Итого: ${total}")
    
    return total  # Возвращаем итоговую сумму


# Запускаем программу
get_card_value()
