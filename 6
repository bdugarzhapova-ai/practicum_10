def check_message(message):
    """Обрезает сообщение, если оно длиннее 160 символов."""
    
    # Проверяем длину сообщения
    if len(message) <= 160:
        return message  # Если короткое - возвращаем как есть
    else:
        return message[:160]  # Если длинное - обрезаем до 160 символов


# Запрашиваем сообщение у пользователя
msg = input("Введите сообщение: ")

# Выводим результат (исходное или обрезанное сообщение)
print(check_message(msg))
