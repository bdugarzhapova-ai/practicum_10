def counter(sentence):
    """
    Считаем гласные и согласные буквы в предложении
    """
    
    # Переводим всё в нижний регистр, чтобы буквы не различались по размеру
    sentence = sentence.lower()
    
    # Счётчики для гласных и согласных
    count_vowels = 0
    count_consonants = 0
    
    # Список всех гласных букв русского алфавита
    vowels = ["а", "е", "и", "о", "у", "ы", "э", "ю", "я", "ё"]
    
    # Список всех согласных букв русского алфавита
    consonants = [
        "ж", "з", "б", "в", "г", "д", "й", "к", "л", "м",
        "н", "п", "р", "с", "т", "ф", "х", "ц", "ч", "ш",
        "щ", "ь", "ъ"
    ]
    
    # Перебираем каждый символ в предложении по очереди
    for char in sentence:
        # Если символ есть в списке гласных - добавляем 1 к счётчику гласных
        if char in vowels:
            count_vowels += 1
        # Если символ есть в списке согласных - добавляем 1 к счётчику согласных
        elif char in consonants:
            count_consonants += 1
        # Остальные символы (пробелы, запятые, точки) просто пропускаем
    
    # Выводим результат: сначала гласные, потом согласные
    print(count_vowels, count_consonants)


# Проверяем работу функции на примере
sentence = " Привет, есть хочу awful"
counter(sentence)
