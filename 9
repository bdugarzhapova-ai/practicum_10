def seconds_from_new_year(date_str):
    """Считает количество секунд от начала года до указанной даты."""
    
    # Разделяем строку на дату и время
    date_part, time_part = date_str.split()
    
    # Разбираем дату (месяц/день/год)
    month, day, year = date_part.split('/')
    
    # Разбираем время (часы:минуты:секунды)
    hour, minute, sec = time_part.split(':')
    
    # Преобразуем всё в числа
    month = int(month)
    day = int(day)
    hour = int(hour)
    minute = int(minute)
    sec = int(sec)
    
    # Количество дней в каждом месяце (индекс 0 не используется)
    month_days = [0, 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    
    # Считаем общее количество дней от начала года
    days = 0
    for m in range(1, month):  # Суммируем дни всех полных месяцев
        days += month_days[m]
    days += day - 1  # Прибавляем дни текущего месяца (минус 1, т.к. сегодняшний день не прошёл)
    
    # Переводим дни в секунды + добавляем секунды текущего дня
    seconds = days * 86400 + hour * 3600 + minute * 60 + sec
    
    return seconds  # Возвращаем общее количество секунд


# Проверяем работу функции
print(seconds_from_new_year("01/15/2024 12:30:45"))
