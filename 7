def common_multiples(A, B, N):
    """Находит и выводит общие кратные чисел A и B до N."""
    
    # Перебираем числа от 1 до N
    for i in range(1, N + 1):
        # Проверяем, делится ли i на A И на B
        if i % A == 0 and i % B == 0:
            print(i, end=" ")  # Выводим число в одну строку


# Запрашиваем три числа у пользователя
A = int(input("Введите число A: "))
B = int(input("Введите число B: "))
N = int(input("Введите число N: "))

# Запускаем поиск общих кратных
common_multiples(A, B, N)
