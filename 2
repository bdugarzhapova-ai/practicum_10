def fibonacci(n):
    """Выводит n чисел последовательности Фибоначчи."""
    
    # Первые два числа последовательности
    a = 1
    b = 1
    
    # Выводим n чисел
    for i in range(n):
        print(a, end=" ")  # Печатаем текущее число
        c = a + b          # Вычисляем следующее число
        a = b              # Сдвигаем первое число
        b = c              # Сдвигаем второе число


# Вызываем функцию для 8 чисел
fibonacci(8)
